# Copy this file to .env and fill in values before running the pipeline.

# Compute device for PyTorch models (mps = Apple Silicon GPU, cpu = fallback)
DEVICE=mps

# Whisper model size: tiny, base, small, medium, large-v3
# Note: Whisper runs on CPU regardless of DEVICE — MPS sparse ops unsupported in torch 2.2.2
WHISPER_MODEL=small

# Pipeline stage toggles
ENABLE_DIARIZATION=true
ENABLE_NONVERBAL=true
ENABLE_EMOTION=true
ENABLE_OCR=true
ENABLE_SCREENSHARE=true

# Minimum confidence threshold for emotion events (0.0–1.0)
EMOTION_MIN_CONFIDENCE=0.50

# Minimum confidence threshold for nonverbal action events (0.0–1.0)
ACTION_MIN_CONFIDENCE=0.50

# Directory paths (defaults shown; override if needed)
INPUT_DIR=./videos
OUTPUT_DIR=./output
TMP_DIR=./tmp
LOG_DIR=./logs

# Audio extraction sample rate (Hz)
AUDIO_SAMPLE_RATE=16000

# Frame sampling rate for visual analysis (frames per second, integer)
FRAME_SAMPLE_RATE=1

# Save intermediate files (extracted WAV, sampled frames) after pipeline run
SAVE_INTERMEDIATE_FILES=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
